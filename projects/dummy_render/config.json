{
  "project": {
    "project_id": "dummy_render",
    "title": "The Walls Groaned",
    "description": "Demo project — a dialogue scene in a decaying room",
    "created_at": "2026-04-18T10:00:00Z",
    "author": "CoAuthor Studio"
  },
  "mode": {
    "type": "fiction",
    "subtype": "general",
    "language": "en"
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.2,
    "api_key_env": "OPENAI_API_KEY",
    "tool_mode": "enabled"
  },
  "chapters": {
    "enabled": true,
    "no_chapters": false,
    "chapters_dir": "fiction/chapters/",
    "default_current_chapter": "chapter_001",
    "allow_chapter_switching": true
  },
  "interface": {
    "show_last_finalized_segments": true,
    "last_finalized_segment_count": 8,
    "allow_manual_override": true,
    "show_module_warnings": true,
    "show_module_suggestions": true,
    "show_current_chapter": true,
    "submit_token": ";;",
    "manuscript_view_enabled": true,
    "manuscript_line_spacing": "double",
    "typewriter_theme": true,
    "typewriter_sounds": false
  },
  "document": {
    "draft_file": "draft.md",
    "history_file": "sentence_history.jsonl",
    "export_format_defaults": ["md", "txt"]
  },
  "modules": {
    "dictionary": {
      "enabled": true,
      "order": 1,
      "settings": {
        "suggest_on_input": true,
        "allow_cli_search": true
      }
    },
    "thesaurus": {
      "enabled": true,
      "order": 2,
      "settings": {
        "suggest_on_input": true,
        "allow_cli_search": true,
        "max_synonym_groups": 5
      }
    },
    "translate": {"enabled": false, "order": 3, "settings": {}},
    "match_style_of_author": {"enabled": false, "order": 4, "settings": {}},
    "character_consistency": {"enabled": false, "order": 5, "settings": {}},
    "world_rule_check": {"enabled": false, "order": 6, "settings": {}},
    "claim_grounding": {"enabled": false, "order": 7, "settings": {}},
    "citation_suggestion": {"enabled": false, "order": 8, "settings": {}}
  },
  "knowledge_sources": {
    "rules_file": "fiction/RULES.md",
    "characters_file": "fiction/CHARACTERS.md",
    "glossary_file": "knowledge/glossary.json",
    "papers_file": "knowledge/papers.json",
    "style_corpus_dir": "stores/style_corpus/",
    "plot_file": "fiction/PLOT.md",
    "feedback_file": "fiction/FEEDBACK.md",
    "places_file": "fiction/PLACES.md",
    "style_file": "fiction/STYLE.md",
    "timeline_file": "fiction/TIMELINE.md"
  },
  "policies": {
    "allow_warning_bypass": true,
    "preserve_raw_input": true,
    "require_explicit_finalize": true
  },
  "lexical_backends": {
    "dictionary": {
      "type": "file",
      "paths": [
        "resources/dictionary/dictionary_compact.json"
      ]
    },
    "thesaurus": {
      "type": "file",
      "paths": [
        "resources/thesaurus/moby.json"
      ]
    }
  }
}
